      "cell_type": "code",
      "source": [
        "def crop_explainer(N,P,K,temperature,humidity,ph,rainfall):\n",
        "\n",
        "    sample = pd.DataFrame([{\n",
        "        \"N\": N,\n",
        "        \"P\": P,\n",
        "        \"K\": K,\n",
        "        \"temperature\": temperature,\n",
        "        \"humidity\": humidity,\n",
        "        \"ph\": ph,\n",
        "        \"rainfall\": rainfall\n",
        "    }])\n",
        "\n",
        "    crop = crop_model.predict(sample)[0]\n",
        "\n",
        "    explanation = []\n",
        "\n",
        "    # Simple reasoning rules (important for UI)\n",
        "    if rainfall > 180:\n",
        "        explanation.append(\"High rainfall supports water-intensive crops\")\n",
        "\n",
        "    if humidity > 70:\n",
        "        explanation.append(\"High humidity favors tropical crops\")\n",
        "\n",
        "    if N > 80:\n",
        "        explanation.append(\"High nitrogen supports leafy crops\")\n",
        "\n",
        "    if 6 <= ph <= 7.5:\n",
        "        explanation.append(\"Soil pH is ideal for most crops\")\n",
        "\n",
        "    if temperature > 20 and temperature < 30:\n",
        "        explanation.append(\"Moderate temperature is optimal for growth\")\n",
        "\n",
        "    return crop, explanation"
      ],
