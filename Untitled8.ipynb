    {
      "cell_type": "code",
      "source": [
        "crop_encoder = LabelEncoder()\n",
        "season_encoder = LabelEncoder()\n",
        "state_encoder = LabelEncoder()\n",
        "\n",
        "crop_yield[\"Crop\"] = crop_encoder.fit_transform(\n",
        "    crop_yield[\"Crop\"]\n",
        ")\n",
        "\n",
        "crop_yield[\"Season\"] = season_encoder.fit_transform(\n",
        "    crop_yield[\"Season\"]\n",
        ")\n",
        "\n",
        "crop_yield[\"State\"] = state_encoder.fit_transform(\n",
        "    crop_yield[\"State\"]\n",
        ")"
      ],
      "metadata": {
        "id": "4MVcUWhYlnLU"
      },
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "features = [\n",
        "    \"Crop\",\n",
        "    \"Crop_Year\",\n",
        "    \"Season\",\n",
        "    \"State\",\n",
        "    \"Area\",\n",
        "    \"Annual_Rainfall\",\n",
        "    \"Fertilizer\",\n",
        "    \"Pesticide\"\n",
        "]\n",
        "\n",
        "X = crop_yield[features]\n",
        "\n",
        "y = crop_yield[\"Yield\"]"
      ],
      "metadata": {
        "id": "0XixMZcqlnN5"
      },
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "X_train,X_test,y_train,y_test = train_test_split(\n",
        "    X,\n",
