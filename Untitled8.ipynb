        "def fertilizer_recommendation(\n",
        "    N,\n",
        "    P,\n",
        "    K\n",
        "):\n",
        "\n",
        "    rec=[]\n",
        "\n",
        "    if N<50:\n",
        "        rec.append(\n",
        "            \"Apply Urea\"\n",
        "        )\n",
        "\n",
        "    if P<40:\n",
        "        rec.append(\n",
        "            \"Apply DAP\"\n",
        "        )\n",
        "\n",
        "    if K<40:\n",
        "        rec.append(\n",
        "            \"Apply MOP\"\n",
        "        )\n",
        "\n",
        "    if len(rec)==0:\n",
        "        rec.append(\n",
        "            \"Soil nutrients are sufficient\"\n",
        "        )\n",
        "\n",
        "    return rec"
      ],
      "metadata": {
        "id": "oyhPBgYflnVt"
      },
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "def soil_health_score(\n",
        "    N,\n",
        "    P,\n",
        "    K,\n",
        "    ph\n",
        "):\n",
        "\n",
        "    score=20\n",
        "\n",
        "    if N<50:\n",
        "        score-=15\n",
        "\n",
        "    if P<40:\n",
        "        score-=15\n",
        "\n",
        "    if K<40:\n",
        "        score-=15\n",
        "\n",
        "    if ph<5.5 or ph>8:\n",
        "        score-=20\n",
        "\n",
        "    return score"
      ],
      "metadata": {
        "id": "5f97xs3VlnYf"
      },
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "def profit_prediction(\n",
        "    yield_value,\n",
        "    market_price,\n",
        "    cost\n",
        "):\n",
        "\n",
        "    revenue = yield_value*market_price\n",
        "\n",
        "    profit = revenue-cost\n",
        "\n",
        "    return revenue,profit"
      ],
      "metadata": {
        "id": "0VQoR3blnn0D"
      },
      "execution_count": null,
      "outputs": []
    },
