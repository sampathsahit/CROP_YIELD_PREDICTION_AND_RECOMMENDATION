      "source": [
        "def recommend_crop(\n",
        "    N,\n",
        "    P,\n",
        "    K,\n",
        "    temperature,\n",
        "    humidity,\n",
        "    ph,\n",
        "    rainfall\n",
        "):\n",
        "\n",
        "    sample = [[\n",
        "        N,\n",
        "        P,\n",
        "        K,\n",
        "        temperature,\n",
        "        humidity,\n",
        "        ph,\n",
        "        rainfall\n",
        "    ]]\n",
        "\n",
        "    crop = crop_model.predict(sample)[0]\n",
        "\n",
        "    probs = crop_model.predict_proba(sample)[0]\n",
        "\n",
        "    confidence = round(max(probs)*100,2)\n",
        "\n",
        "    return crop,confidence"
      ],
      "metadata": {
        "id": "0jRMOqLVlnGh"
      },
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "crop,confidence = recommend_crop(\n",
        "    10,\n",
        "    13,\n",
        "    4,\n",
        "    21,\n",
        "    82,\n",
        "    6.5,\n",
        "    200\n",
        ")\n",
        "\n",
        "print(crop)\n",
        "print(confidence,\"%\")"
      ],
