        "    test_size=0.2,\n",
        "    random_state=42\n",
        ")\n",
        "\n",
        "yield_model = RandomForestRegressor(\n",
        "    n_estimators=300,\n",
        "    random_state=42\n",
        ")\n",
        "\n",
        "yield_model.fit(X_train,y_train)\n",
        "\n",
        "pred = yield_model.predict(X_test)\n",
        "\n",
        "print(\n",
        "    \"R2 Score:\",\n",
        "    r2_score(y_test,pred)\n",
        ")"
      ],
